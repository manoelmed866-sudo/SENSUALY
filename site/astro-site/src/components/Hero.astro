---
import { BRAND, whatsappLink, INSTAGRAM } from '../consts';
---

<section id="topo" class="hero">
  <div class="container hero-inner">
    <div class="hero-logo-wrap">
      <div class="hero-logo-stack">
        <img src="/logo.png" alt="" class="hero-logo hero-logo-simbolo" width="597" height="933" draggable="false" />
        <img src="/logo.png" alt="Sensually" class="hero-logo hero-logo-nome" width="597" height="933" draggable="false" />
      </div>
    </div>
    <h1 class="hero-title">
      <span class="title-serif">{BRAND.tagline}</span>
    </h1>
    <p class="eyebrow">Moda · Acessórios · Presentes</p>
    <p class="hero-sub">{BRAND.descricao}</p>
    <div class="hero-cta">
      <a href={whatsappLink()} class="btn btn-primary" target="_blank" rel="noopener">
        Comprar pelo WhatsApp
      </a>
      <a href={INSTAGRAM.principal.url} class="btn btn-ghost" target="_blank" rel="noopener">
        Ver no Instagram
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 80px 0 100px;
    text-align: center;
    background: var(--cream); /* mesmo tom do fundo da logo, pra ela fundir */
  }
  .hero-inner { max-width: 760px; }
  .hero-logo-wrap {
    display: flex;
    justify-content: center;
    margin: 0 auto 1.2rem;
    animation: flutuar 6s ease-in-out infinite;
  }
  .hero-logo-stack {
    position: relative;
    width: clamp(210px, 26vw, 280px);
    aspect-ratio: 597 / 933;
    /* fundo já é transparente (PNG processado e recortado) — a sombra dá o efeito de flutuação real */
    filter: drop-shadow(0 24px 28px rgba(74, 43, 34, 0.22))
            drop-shadow(0 4px 8px rgba(74, 43, 34, 0.12));
  }
  .hero-logo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  /* Camada de cima: a ilustração + o "S" grande. Mostra só os 75% de cima. */
  .hero-logo-simbolo {
    clip-path: inset(0 0 25% 0);
  }
  /* Camada de baixo: a palavra "Sensually". Mostra só os 25% de baixo,
     deslocada um pouco pra direita (ajuste o valor abaixo conforme necessário). */
  .hero-logo-nome {
    clip-path: inset(75% 0 0 0);
    transform: translateX(10px);
  }
  @keyframes flutuar {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-14px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-logo-wrap { animation: none; }
  }
  .hero-title {
    margin: 0 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .hero-title .title-serif {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    color: var(--ink);
    font-weight: 400;
  }
  .hero-sub {
    color: var(--ink-soft);
    font-size: 1.08rem;
    max-width: 520px;
    margin: 0 auto 2rem;
    font-weight: 300;
  }
  .hero-cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
