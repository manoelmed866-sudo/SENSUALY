---
// Faixa editorial. As imagens entram depois (basta colocar arquivos em
// public/destaques/ e trocar os src). Por enquanto usa placeholders elegantes.
const destaques = [
  { titulo: 'Denim', texto: 'A base que combina com tudo.' },
  { titulo: 'Fitness', texto: 'Conforto pra treinar com atitude.' },
  { titulo: 'Presentes', texto: 'A peça certa pra cada ocasião.' },
  { titulo: 'Acessórios', texto: 'O detalhe que fecha o look.' },
];
---

<section id="destaques" class="destaques">
  <div class="container">
    <div class="head">
      <p class="eyebrow">Editorial</p>
      <h2 class="title-serif">Destaques da loja</h2>
    </div>

    <div class="strip">
      {destaques.map((d) => (
        <div class="tile">
          <div class="tile-img" aria-hidden="true"></div>
          <h3 class="tile-title title-serif">{d.titulo}</h3>
          <p class="tile-text">{d.texto}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .destaques { background: var(--cream); }
  .head { text-align: center; margin-bottom: 3rem; }
  .head h2 { font-size: clamp(2rem, 5vw, 2.8rem); margin-top: 0.5rem; }

  .strip {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.2rem;
  }
  .tile-img {
    aspect-ratio: 4 / 5;
    border-radius: 12px;
    background: linear-gradient(160deg, #efe7da 0%, #e3d7c4 100%);
    border: 1px solid var(--line);
    margin-bottom: 1rem;
  }
  .tile-title { font-size: 1.3rem; }
  .tile-text { color: var(--ink-soft); font-size: 0.92rem; font-weight: 300; }

  @media (max-width: 820px) {
    .strip { grid-template-columns: repeat(2, 1fr); }
  }
</style>
