---
import { FRENTES } from '../consts';
---

<section id="frentes" class="frentes">
  <div class="container">
    <div class="head">
      <p class="eyebrow">Três jeitos de combinar com você</p>
      <h2 class="title-serif">Nossas coleções</h2>
    </div>

    <div class="grid">
      {FRENTES.map((f) => (
        <article class="card">
          <p class="card-tag">{f.etiqueta}</p>
          <h3 class="card-title title-serif">{f.nome}</h3>
          <p class="card-text">{f.texto}</p>
          <a href={f.instagram.url} class="card-link" target="_blank" rel="noopener">
            {f.instagram.handle} →
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .frentes { background: var(--cream-soft); }
  .head { text-align: center; margin-bottom: 3rem; }
  .head h2 { font-size: clamp(2rem, 5vw, 2.8rem); margin-top: 0.5rem; }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .card {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 2.2rem 1.8rem;
    display: flex;
    flex-direction: column;
    min-height: 240px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 14px 30px rgba(27, 26, 24, 0.07);
  }
  .card-tag {
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 0.8rem;
  }
  .card-title { font-size: 1.8rem; margin-bottom: 0.7rem; }
  .card-text { color: var(--ink-soft); font-weight: 300; flex: 1; }
  .card-link {
    margin-top: 1.4rem;
    font-size: 0.9rem;
    font-weight: 500;
  }
  .card-link:hover { color: var(--ink-soft); }

  @media (max-width: 820px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
