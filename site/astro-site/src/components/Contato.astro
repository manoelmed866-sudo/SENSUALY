---
import { whatsappLink, INSTAGRAM } from '../consts';
---

<section id="contato" class="contato">
  <div class="container box">
    <p class="eyebrow">Fala com a gente</p>
    <h2 class="title-script">Vamos montar seu look?</h2>
    <p class="sub">
      Atendimento e encomendas direto no WhatsApp. Mostramos novidades todo dia
      no Instagram.
    </p>
    <div class="cta">
      <a href={whatsappLink()} class="btn btn-primary" target="_blank" rel="noopener">
        Chamar no WhatsApp
      </a>
      <a href={INSTAGRAM.principal.url} class="btn btn-ghost" target="_blank" rel="noopener">
        Seguir no Instagram
      </a>
    </div>
  </div>
</section>

<style>
  .contato { background: var(--cream-soft); }
  .box {
    max-width: 640px;
    text-align: center;
  }
  .box h2 {
    font-size: clamp(2.6rem, 7vw, 4rem);
    margin: 0.6rem 0 1rem;
  }
  .sub {
    color: var(--ink-soft);
    font-weight: 300;
    margin-bottom: 2rem;
  }
  .cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
